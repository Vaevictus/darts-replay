[Unit]
Description=Darts Replay (instant replay for autodarts)
After=graphical-session.target network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/darts-replay
# Node is installed user-space in ~/.local/node (no system Node on the box).
Environment=PATH=%h/.local/node/bin:/usr/local/bin:/usr/bin:/bin
Environment=NODE_ENV=production
ExecStart=%h/.local/node/bin/npm start
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
